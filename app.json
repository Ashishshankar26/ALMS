{
  "expo": {
    "name": "ALMS",
    "slug": "lpu-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "alms",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#4C0099"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.ashish.alms",
      "softwareKeyboardLayoutMode": "pan",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4C0099"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4C0099"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4673d8c-1de3-450a-bc76-184ac8280f88"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/d4673d8c-1de3-450a-bc76-184ac8280f88"
    },
    "runtimeVersion": "1.0.0"
  }
}
